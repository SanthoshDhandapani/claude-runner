{
  "name": "claude-runner",
  "version": "0.4.1",
  "description": "The easiest way to build AI agents with Claude. MCP-native, sandbox-first, 5 lines to start.",
  "type": "module",
  "main": "dist/index.js",
  "types": "dist/index.d.ts",
  "bin": {
    "claude-runner": "./dist/cli.js"
  },
  "exports": {
    ".": {
      "import": "./dist/index.js",
      "types": "./dist/index.d.ts"
    }
  },
  "files": [
    "dist",
    "README.md",
    "LICENSE"
  ],
  "scripts": {
    "build": "tsc",
    "dev": "tsc --watch",
    "test": "node --test test/index.test.js",
    "clean": "rm -rf dist",
    "prepublishOnly": "npm run build"
  },
  "keywords": [
    "claude",
    "agent",
    "ai",
    "sdk",
    "mcp",
    "sandbox",
    "e2b",
    "anthropic",
    "runner",
    "coding-agent"
  ],
  "author": "Santhosh Dhandapani",
  "license": "MIT",
  "repository": {
    "type": "git",
    "url": "https://github.com/SanthoshDhandapani/claude-runner.git"
  },
  "homepage": "https://github.com/SanthoshDhandapani/claude-runner",
  "engines": {
    "node": ">=18"
  },
  "dependencies": {
    "@anthropic-ai/claude-agent-sdk": "^0.2.97"
  },
  "peerDependencies": {
    "@anthropic-ai/sdk": ">=0.30.0",
    "e2b": "^2.19.0",
    "zod": ">=3.0.0"
  },
  "peerDependenciesMeta": {
    "@anthropic-ai/sdk": {
      "optional": true
    },
    "e2b": {
      "optional": true
    },
    "zod": {
      "optional": true
    }
  },
  "devDependencies": {
    "@types/node": "^22.15.29",
    "typescript": "^5.9.3"
  }
}
